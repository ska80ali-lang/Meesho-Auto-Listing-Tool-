{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/create-cashfree-order",
      "destination": "/api/create-cashfree-order.ts"
    },
    {
      "source": "/api/verify-cashfree-order",
      "destination": "/api/verify-cashfree-order.ts"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
